<?xml version="1.0" encoding="utf-8"?>
<robot name="wafl2025">

  <!-- ==================== BASE ==================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.559" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0.14764 -8.6961E-05 -0.19475" rpy="0 0 0"/>
      <mass value="75.51"/>
      <inertia ixx="1.7717" ixy="0.0070117" ixz="-0.21444"
               iyy="2.3738" iyz="0.11565" izz="1.7629"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://wafl2026/meshes/base_link.STL"/></geometry>
      <material name="grey"><color rgba="0.7 0.7 0.7 1"/></material>
    </visual>
    <collision>
      <geometry><mesh filename="package://wafl2026/meshes/base_link.STL"/></geometry>
    </collision>
  </link>

  <!-- ==================== LEFT WEB + WHEEL ==================== -->
  <link name="left_web">
    <inertial>
      <origin xyz="-0.000209 -0.0002904 0.057128" rpy="0 0 0"/>
      <mass value="1.4293"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://wafl2026/meshes/left_web.STL"/></geometry>
    </visual>
    <collision>
      <geometry><mesh filename="package://wafl2026/meshes/left_web.STL"/></geometry>
    </collision>
  </link>

  <joint name="leftweb" type="fixed">
    <origin xyz="0.37473 0.16927 -0.351" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="left_web"/>
  </joint>

  <link name="left_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://wafl2026/meshes/left_wheel.STL"/></geometry>
    </visual>
    <collision>
      <geometry><mesh filename="package://wafl2026/meshes/left_wheel.STL"/></geometry>
    </collision>
  </link>

  <joint name="leftwheel" type="continuous">
    <origin xyz="0 0 -0.17" rpy="-1.5708 0 0"/>
    <parent link="left_web"/>
    <child link="left_wheel"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="10.0" friction="1.0"/>
  </joint>

  <!-- ==================== RIGHT WEB + WHEEL ==================== -->
  <link name="right_web">
    <inertial>
      <origin xyz="0.00013451 -0.00030111 0.05303" rpy="0 0 0"/>
      <mass value="1.5507"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://wafl2026/meshes/right_web.STL"/></geometry>
    </visual>
    <collision>
      <geometry><mesh filename="package://wafl2026/meshes/right_web.STL"/></geometry>
    </collision>
  </link>

  <joint name="rightweb" type="fixed">
    <origin xyz="0.37493 -0.17027 -0.351" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="right_web"/>
  </joint>

  <link name="right_wheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://wafl2026/meshes/right_wheel.STL"/></geometry>
    </visual>
    <collision>
      <geometry><mesh filename="package://wafl2026/meshes/right_wheel.STL"/></geometry>
    </collision>
  </link>

  <joint name="rightwheel" type="continuous">
    <origin xyz="0 0 -0.17" rpy="-1.5708 0 0"/>
    <parent link="right_web"/>
    <child link="right_wheel"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="10.0" friction="1.0"/>
  </joint>

  <!-- ==================== CASTOR ASSEMBLY ==================== -->
  <link name="castor">
    <inertial>
      <origin xyz="-0.014681 8.0115E-06 -0.033862" rpy="0 0 0"/>
      <mass value="1.5287"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://wafl2026/meshes/castor.STL"/></geometry>
    </visual>
    <collision>
      <geometry><mesh filename="package://wafl2026/meshes/castor.STL"/></geometry>
    </collision>
  </link>

  <joint name="castorjoint" type="continuous">
    <origin xyz="-0.087559 0 -0.374" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="castor"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <link name="castor_wheel">
    <inertial>
      <origin xyz="5.8206E-05 -1.471E-05 -0.038908" rpy="0 0 0"/>
      <mass value="1.5287"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://wafl2026/meshes/castor_wheel.STL"/></geometry>
    </visual>
    <collision>
      <geometry><mesh filename="package://wafl2026/meshes/castor_wheel.STL"/></geometry>
    </collision>
  </link>

  <joint name="castorwheel" type="continuous">
    <origin xyz="0.0087891 0.018594 -0.15" rpy="-1.5708 0 0"/>
    <parent link="castor"/>
    <child link="castor_wheel"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="1.0" friction="0.1"/>
  </joint>

  <!-- ==================== IMU ==================== -->
  <link name="imu_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>
  
  <link name="rplidar_link">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.05" length="0.06"/></geometry>
      <material name="Orange"><color rgba="1 0.5 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.05" length="0.06"/></geometry>
    </collision>
  </link>

  <joint name="rplidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rplidar_link"/>
    <origin xyz="0.59 0 0.5" rpy="0 0 0"/>
  </joint>

  <link name="kinect_link">
    <visual>
      <geometry><mesh filename="package://wafl2026/meshes/kinect.dae" scale="1 1 1"/></geometry>
      <material name="Green"><color rgba="0 1 0 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.073 0.276 0.072"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.005" iyy="0.005" izz="0.005" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="kinect_joint" type="fixed">
    <parent link="base_link"/>
    <child link="kinect_link"/>
    <origin xyz="0.65 0 0.42" rpy="0 0 0"/>
  </joint>

  <!-- ==================== GAZEBO IGNITION PLUGINS ==================== -->
  <gazebo>
  <plugin
    filename="ignition-gazebo-sensors-system"
    name="ignition::gazebo::systems::Sensors">
    <render_engine>ogre2</render_engine>
  </plugin>
</gazebo>
  <gazebo reference="rplidar_link">
    <sensor name="gpu_lidar" type="gpu_lidar">
    <gz_frame_id>rplidar_link</gz_frame_id>
      <pose>0 0 0 0 0 0</pose>
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>640</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
        </range>
      </lidar>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="kinect_link">
    <sensor name="kinect_camera" type="rgbd_camera">
      <topic>kinect</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>8.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>
  
  <gazebo reference="imu_link">
  <sensor name="imu_sensor" type="imu">
    <always_on>1</always_on>
    <update_rate>100</update_rate>
    <topic>imu</topic>
    <gz_frame_id>imu_link</gz_frame_id>
  </sensor>
</gazebo>
  
  <gazebo>

    <!-- Differential Drive -->
    <plugin
      filename="ignition-gazebo-diff-drive-system"
      name="ignition::gazebo::systems::DiffDrive">
      <left_joint>leftwheel</left_joint>
      <right_joint>rightwheel</right_joint>
      <!-- wheel_separation = left_y + right_y = 0.16927 + 0.17027 = 0.33954 m -->
      <!-- wheel_radius: tune to match your STL - start with 0.10 m -->
      <wheel_separation>0.34</wheel_separation>
      <wheel_radius>0.10</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <odom_publish_frequency>30</odom_publish_frequency>
      <publish_odom_tf>false</publish_odom_tf>
    </plugin>

    <!-- Joint State Publisher - only moving joints -->
    <plugin
      filename="ignition-gazebo-joint-state-publisher-system"
      name="ignition::gazebo::systems::JointStatePublisher">
      <topic>/joint_states</topic>
      <joint_name>leftwheel</joint_name>
      <joint_name>rightwheel</joint_name>
      <joint_name>castorjoint</joint_name>
      <joint_name>castorwheel</joint_name>
    </plugin>

    <!-- IMU System -->
    <plugin
      filename="ignition-gazebo-imu-system"
      name="ignition::gazebo::systems::Imu">
    </plugin>

  </gazebo>

  <!-- Surface properties for drive wheels (Extremely high friction for traction) -->
	<gazebo reference="left_wheel">
		<implicitSpringDamper>true</implicitSpringDamper>
		<mu1>100.0</mu1>
		<mu2>100.0</mu2>
		<kp>10000000.0</kp>
		<kd>1.0</kd>
		<minDepth>0.001</minDepth>
	</gazebo>

	<gazebo reference="right_wheel">
		<implicitSpringDamper>true</implicitSpringDamper>
		<mu1>100.0</mu1>
		<mu2>100.0</mu2>
		<kp>10000000.0</kp>
		<kd>1.0</kd>
		<minDepth>0.001</minDepth>
	</gazebo>

	<!-- Castor wheel: low friction to prevent catching, but enough to avoid erratic slipping -->
	<gazebo reference="castor_wheel">
		<mu1>0.0</mu1>
		<mu2>0.0</mu2>
		<kp>1000000.0</kp>
		<kd>10.0</kd>
	</gazebo>

  <gazebo reference="castor">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>
  
  
<gazebo>
  <plugin
    filename="ignition-gazebo-joint-position-controller-system"
    name="ignition::gazebo::systems::JointPositionController">
    <joint_name>castorjoint</joint_name>
    <topic>castor_cmd_pos</topic> <p_gain>50.0</p_gain>
    <i_gain>0.1</i_gain>
    <d_gain>1.0</d_gain>
  </plugin>
  
  <!-- Individual wheel/steering controllers removed: DiffDrive handles leftwheel/rightwheel via /cmd_vel -->
</gazebo>




</robot>
