<?xml version="1.0" encoding="utf-8"?>
<robot name="wafl2025">

  <link name="base_footprint"/>

  <joint name="chassis_base_footprint" type="fixed">
    <origin xyz="0 0 0.559" rpy="0 0 0"/>  
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0.44764 -8.6961E-05 -0.19475" rpy="0 0 0" />
      <mass value="75.51" />
      <inertia ixx="1.7717" ixy="0.0070117" ixz="-0.21444" iyy="2.3738" iyz="0.11565" izz="1.7629" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://wafl2025/meshes/base_link.STL" /></geometry>
      <material name="grey"><color rgba="0.7 0.7 0.7 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="package://wafl2025/meshes/base_link.STL" /></geometry>
    </collision>
  </link>

  <gazebo reference="base_link">
    <mu1>0.01</mu1>
    <mu2>0.01</mu2>
  </gazebo>

  <gazebo reference="left_wheel">
    <mu1>200.0</mu1>
    <mu2>200.0</mu2>
    <kp>100000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <gazebo reference="right_wheel">
    <mu1>200.0</mu1>
    <mu2>200.0</mu2>
    <kp>100000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <gazebo>
    <plugin
      filename="ignition-gazebo-diff-drive-system"
      name="ignition::gazebo::systems::DiffDrive">
      <left_joint>leftwheel</left_joint>
      <right_joint>rightwheel</right_joint>
      <wheel_separation>0.5</wheel_separation>
      <wheel_radius>0.025</wheel_radius> <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>

  <plugin
    filename="ignition-gazebo-joint-state-publisher-system"
    name="ignition::gazebo::systems::JointStatePublisher">
    <topic>joint_states</topic> <joint_name>leftwheel</joint_name>
    <joint_name>rightwheel</joint_name>
    <joint_name>leftweb</joint_name>
    <joint_name>rightweb</joint_name>
    <joint_name>castorjoint</joint_name>
    <joint_name>castorwheel</joint_name>
  </plugin>
  
  </gazebo>

</robot>
